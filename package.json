    "configuration": {
      "title": "YouTrack",
      "properties": {
        "youtrack.baseUrl": {
          "type": "string",
          "default": "",
          "description": "YouTrack Cloud base URL."
        },
        "youtrack.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Short name of project used by Create Issue when set."
        },
        "youtrack.statusBarQuery": {
          "type": "string",
          "default": "for: me and #Unresolved",
          "description": "Query for the status bar counter."
        },
        "youtrack.assignedToMeQuery": {
          "type": "string",
          "default": "for: me",
          "markdownDescription": "YouTrack query for the **Assigned to me** sidebar view. Overrides any saved search named 'Assigned to me' on your YouTrack — what you put here is exactly what the extension fetches.\n\nLeave the resolved filter out of this query if you want the **Hide resolved / Show resolved too** toggle in the view title to actually do something — that toggle filters client-side, so the resolved issues need to be in the fetched payload first.\n\nReload the window after editing."
        },
        "youtrack.cache.ttl.issues": {
          "type": "number",
          "default": 60,
          "description": "Issue cache TTL (seconds)."
        },
        "youtrack.cache.ttl.fieldSchemas": {
          "type": "number",
          "default": 3600,
          "description": "Custom field schemas TTL (seconds)."
        },
        "youtrack.cache.ttl.savedSearches": {
          "type": "number",
          "default": 300,
          "description": "Saved searches TTL (seconds)."
        },
        "youtrack.cache.pollInterval": {
          "type": "number",
          "default": 60,
          "description": "Background refresh interval (seconds)."
        },
        "youtrack.branch.template": {
          "type": "string",
          "default": "{assignee}/{id}-{summary}",
          "markdownDescription": "Branch name template. Available placeholders:\n\n- `{id}` — issue id (e.g. `ABC-123`)\n- `{summary}` — issue summary (slugified, truncated by `#youtrack.branch.summaryMaxLength#`)\n- `{type}` — issue type (e.g. `bug`, `feature`)\n- `{state}` — current state (e.g. `in-progress`)\n- `{assignee}` — assignee login\n- `{project}` — project short name\n- `{field:<Name>}` — any custom field by its YouTrack name (e.g. `{field:Subsystem}`)\n\nAll tokens except `{id}` are sanitized: lowercased, diacritics stripped, non-alphanumerics replaced with `#youtrack.branch.separator#`.\n\nExample: `{assignee}/{id}-{summary}` → `alice/ABC-123-fix-login-crash`."
        },
        "youtrack.branch.summaryMaxLength": {
          "type": "number",
          "default": 40,
          "markdownDescription": "Maximum character length of the `{summary}` token after sanitization."
        },
        "youtrack.branch.separator": {
          "type": "string",
          "default": "-",
          "markdownDescription": "Character used to join words inside sanitized tokens (`{summary}`, `{type}`, `{state}`, `{field:…}`)."
        },
        "youtrack.branch.copyOnly": {
          "type": "boolean",
          "default": false,
          "description": "Copy to clipboard instead of creating the branch."
        },
        "youtrack.commit.template": {
          "type": "string",
          "default": "{id}: ",
          "markdownDescription": "Commit-message prefix applied when the current branch contains an issue key. `{id}` is replaced with the issue id. Examples:\n\n- `\"{id}: \"` → `PIPE-619: fix login bug`\n- `\"[{id}] \"` → `[PIPE-619] fix login bug`\n- `\"feat({id}): \"` → `feat(PIPE-619): fix login bug`\n- `\"\\n\\nRefs: {id}\"` as a trailing footer\n\nSee `#youtrack.commit.autoFill#` for when this template is applied automatically."
        },
        "youtrack.commit.autoFill": {
          "type": "string",
          "enum": [
            "off",
            "empty-only",
            "always"
          ],
          "enumDescriptions": [
            "Never auto-fill. Use the 'Insert Issue Key in Commit Message' command manually.",
            "Auto-fill once when the SCM commit box is empty on branch change or panel open.",
            "Re-fill the SCM commit box whenever it becomes empty (e.g. after each commit)."
          ],
          "default": "empty-only",
          "markdownDescription": "When to auto-apply `#youtrack.commit.template#` to the Source Control commit box."
        },
        "youtrack.sidebar.groupBy": {
          "type": "string",
          "enum": [
            "none",
            "project"
          ],
          "default": "project",
          "description": "How to group issues within each saved search in the sidebar."
        },
        "youtrack.ai.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable AI-assisted features. Uses the [Claude Agent SDK](https://docs.anthropic.com/en/docs/agent-sdk), which inherits authentication from the local Claude Code installation (Max/Team plan, API key, Bedrock, or Vertex). Claude Code must be installed and signed in: <https://claude.com/claude-code>."
        },
        "youtrack.ai.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "markdownDescription": "Model used for AI features. Examples: `claude-sonnet-4-6`, `claude-opus-4-7`."
        },
        "youtrack.ai.permissionMode": {
          "type": "string",
          "enum": [
            "default",
            "acceptEdits",
            "bypassPermissions",
            "plan"
          ],
          "enumDescriptions": [
            "Prompt before each tool use (safest).",
            "Auto-approve file/edit tools but prompt for shell.",
            "Skip all permission prompts (use only in trusted projects).",
            "Plan mode — model proposes a plan before acting."
          ],
          "default": "default",
          "description": "How the agent handles tool-use permission prompts. The agent has access to the YouTrack MCP server, so write tools (post comment, transition state, etc.) flow through this gate."
        },
        "youtrack.ai.maxTurns": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of agent turns (model + tool-call loops) per request before stopping."
        },
        "youtrack.ai.draft.checkDuplicates": {
          "type": "boolean",
          "default": true,
          "description": "When drafting a new issue with AI, ask the agent to search YouTrack for similar existing issues and surface them as a soft warning under the summary field. Adds ~1 extra MCP search call per draft."
        },
        "youtrack.ai.codeActions.replaceTodoWithIssueId": {
          "type": "boolean",
          "default": true,
          "description": "After filing an issue from a TODO/FIXME/XXX/HACK/NOTE comment via the Quick Fix, replace the bare marker on that line with one that includes the new issue id (e.g. \"# TODO\" → \"# TODO ABC-123\"). Skipped if the line already contains an issue id."
        },
        "youtrack.ai.codeActions.todoIdFormat": {
          "type": "string",
          "default": "{marker} {id}",
          "markdownDescription": "Format applied when stamping the new issue id onto a TODO comment. `{marker}` is the original marker (e.g. `TODO`); `{id}` is the new issue id (e.g. `ABC-123`). Examples:\n\n- `\"{marker} {id}\"` → `TODO ABC-123` (default)\n- `\"{marker}({id})\"` → `TODO(ABC-123)`\n- `\"{marker}: {id}\"` → `TODO: ABC-123`"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "youtrack.getStarted",
        "title": "Get Started with YouTrack",
        "description": "Sign in, open your first issue, branch from it, and tweak the extension to fit your workflow.",
        "steps": [
          {
            "id": "youtrack.signIn",
            "title": "Sign in to YouTrack",
            "description": "Provide your YouTrack Cloud URL and a permanent token.\n[Sign In](command:youtrack.signIn)",
            "media": {
              "markdown": "media/walkthrough/signin.md"
            },
            "completionEvents": [
              "onCommand:youtrack.signIn"
            ]
          },
          {
            "id": "youtrack.openIssue",
            "title": "Open your first issue",
            "description": "Open an issue from the sidebar or jump to one by ID.\n[Go to Issue](command:youtrack.goToIssue)",
            "media": {
              "markdown": "media/walkthrough/open.md"
            },
            "completionEvents": [
              "onCommand:youtrack.goToIssue",
              "onCommand:youtrack.openIssue"
            ]
          },
          {
            "id": "youtrack.createBranch",
            "title": "Branch from an issue",
            "description": "Right-click an issue → Create Branch. Commit messages then auto-prefix with the issue key.",
            "media": {
              "markdown": "media/walkthrough/branch.md"
            },
            "completionEvents": [
              "onCommand:youtrack.createBranch"
            ]
          },
          {
            "id": "youtrack.customize",
            "title": "Customize",
            "description": "Review the settings and keybindings that make this extension your own.\n[Open Settings](command:workbench.action.openSettings?%22youtrack%22)",
            "media": {
              "markdown": "media/walkthrough/customize.md"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "youtrack",
          "title": "YouTrack",
          "icon": "media/youtrack_outline.svg"
        }
      ]
    },
    "views": {
      "youtrack": [
        {
          "id": "youtrack.notifications",
          "name": "Notifications"
        },
        {
          "id": "youtrack.assignedToMe",
          "name": "Assigned to me"
        },
        {
          "id": "youtrack.recents",
          "name": "Recently opened"
        },
        {
          "id": "youtrack.issues",
          "name": "Issues"
        },
        {
          "id": "youtrack.boards",
          "name": "Agile Boards"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "youtrack.ai.summarizeIssue",
          "when": "youtrack.signedIn && config.youtrack.ai.enabled"
        },
        {
          "command": "youtrack.ai.discussInTerminal",
          "when": "youtrack.signedIn && config.youtrack.ai.enabled"
        },
        {
          "command": "youtrack.ai.createIssue",
          "when": "youtrack.signedIn && config.youtrack.ai.enabled"
        },
        {
          "command": "youtrack.ai.createIssueFromTodo",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "youtrack.createIssueFromSelection",
          "when": "editorHasSelection && youtrack.signedIn",
          "group": "youtrack@1"
        }
      ],
      "view/title": [
        {
          "command": "youtrack.createIssue",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues|boards)$/",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.ai.createIssue",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues|boards)$/ && config.youtrack.ai.enabled",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.assignedToMe.filter",
          "when": "view == youtrack.assignedToMe && !youtrack.assignedToMe.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.assignedToMe.clearFilter",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.assignedToMe.filterByState",
          "when": "view == youtrack.assignedToMe && !youtrack.assignedToMe.stateFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.assignedToMe.clearStateFilter",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.stateFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.assignedToMe.filterByTag",
          "when": "view == youtrack.assignedToMe && !youtrack.assignedToMe.tagFilterActive",
          "group": "navigation@3"
        },
        {
          "command": "youtrack.assignedToMe.clearTagFilter",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.tagFilterActive",
          "group": "navigation@3"
        },
        {
          "command": "youtrack.assignedToMe.hideResolved",
          "when": "view == youtrack.assignedToMe && !youtrack.assignedToMe.unresolvedOnly",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.assignedToMe.showAll",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.unresolvedOnly",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.assignedToMe.clearAllFilters",
          "when": "view == youtrack.assignedToMe && (youtrack.assignedToMe.filterActive || youtrack.assignedToMe.stateFilterActive || youtrack.assignedToMe.tagFilterActive || youtrack.assignedToMe.unresolvedOnly)",
          "group": "navigation@4"
        },
        {
          "command": "youtrack.assignedToMe.sortBy",
          "when": "view == youtrack.assignedToMe",
          "group": "navigation@5"
        },
        {
          "command": "youtrack.assignedToMe.sortAscending",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.sortHasDirection && !youtrack.assignedToMe.sortAscending",
          "group": "navigation@6"
        },
        {
          "command": "youtrack.assignedToMe.sortDescending",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.sortHasDirection && youtrack.assignedToMe.sortAscending",
          "group": "navigation@6"
        },
        {
          "command": "youtrack.assignedToMe.groupFlat",
          "when": "view == youtrack.assignedToMe && youtrack.assignedToMe.groupedByProject",
          "group": "navigation@7"
        },
        {
          "command": "youtrack.assignedToMe.groupByProject",
          "when": "view == youtrack.assignedToMe && !youtrack.assignedToMe.groupedByProject",
          "group": "navigation@7"
        },
        {
          "command": "youtrack.assignedToMe.refresh",
          "when": "view == youtrack.assignedToMe",
          "group": "navigation@8"
        },
        {
          "command": "youtrack.issues.filter",
          "when": "view == youtrack.issues && !youtrack.issues.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.issues.clearFilter",
          "when": "view == youtrack.issues && youtrack.issues.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.issues.filterByState",
          "when": "view == youtrack.issues && !youtrack.issues.stateFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.issues.clearStateFilter",
          "when": "view == youtrack.issues && youtrack.issues.stateFilterActive",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.issues.filterByTag",
          "when": "view == youtrack.issues && !youtrack.issues.tagFilterActive",
          "group": "navigation@3"
        },
        {
          "command": "youtrack.issues.clearTagFilter",
          "when": "view == youtrack.issues && youtrack.issues.tagFilterActive",
          "group": "navigation@3"
        },
        {
          "command": "youtrack.issues.hideResolved",
          "when": "view == youtrack.issues && !youtrack.issues.unresolvedOnly",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.issues.showAll",
          "when": "view == youtrack.issues && youtrack.issues.unresolvedOnly",
          "group": "navigation@0"
        },
        {
          "command": "youtrack.issues.clearAllFilters",
          "when": "view == youtrack.issues && (youtrack.issues.filterActive || youtrack.issues.stateFilterActive || youtrack.issues.tagFilterActive || youtrack.issues.unresolvedOnly)",
          "group": "navigation@4"
        },
        {
          "command": "youtrack.issues.sortBy",
          "when": "view == youtrack.issues",
          "group": "navigation@5"
        },
        {
          "command": "youtrack.issues.sortAscending",
          "when": "view == youtrack.issues && youtrack.issues.sortHasDirection && !youtrack.issues.sortAscending",
          "group": "navigation@6"
        },
        {
          "command": "youtrack.issues.sortDescending",
          "when": "view == youtrack.issues && youtrack.issues.sortHasDirection && youtrack.issues.sortAscending",
          "group": "navigation@6"
        },
        {
          "command": "youtrack.issues.groupFlat",
          "when": "view == youtrack.issues && youtrack.issues.groupedByProject",
          "group": "navigation@7"
        },
        {
          "command": "youtrack.issues.groupByProject",
          "when": "view == youtrack.issues && !youtrack.issues.groupedByProject",
          "group": "navigation@7"
        },
        {
          "command": "youtrack.issues.refresh",
          "when": "view == youtrack.issues",
          "group": "navigation@8"
        },
        {
          "command": "youtrack.refreshBoards",
          "when": "view == youtrack.boards",
          "group": "navigation"
        },
        {
          "command": "youtrack.refreshRecents",
          "when": "view == youtrack.recents",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.clearRecents",
          "when": "view == youtrack.recents",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.refreshNotifications",
          "when": "view == youtrack.notifications",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.markAllNotificationsRead",
          "when": "view == youtrack.notifications",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "youtrack.createBranch",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "inline@1"
        },
        {
          "command": "youtrack.openInBrowser",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "inline@2"
        },
        {
          "command": "youtrack.startWork",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "1_work@1"
        },
        {
          "command": "youtrack.assignToMe",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "1_work@2"
        },
        {
          "command": "youtrack.changeState",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "1_work@3"
        },
        {
          "command": "youtrack.logTime",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "1_work@4"
        },
        {
          "command": "youtrack.createBranch",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "2_branch@1"
        },
        {
          "command": "youtrack.ai.summarizeIssue",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues|recents)$/ && viewItem == issue && config.youtrack.ai.enabled",
          "group": "1_work@5"
        },
        {
          "command": "youtrack.ai.discussInTerminal",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues|recents)$/ && viewItem == issue && config.youtrack.ai.enabled",
          "group": "1_work@6"
        },
        {
          "command": "youtrack.copyId",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "3_copy@1"
        },
        {
          "command": "youtrack.copyLink",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "3_copy@2"
        },
        {
          "command": "youtrack.openInBrowser",
          "when": "view =~ /^youtrack\\.(assignedToMe|issues)$/ && viewItem == issue",
          "group": "3_copy@3"
        },
        {
          "command": "youtrack.openBoardInBrowser",
          "when": "view == youtrack.boards && viewItem == board",
          "group": "inline@1"
        },
        {
          "command": "youtrack.openBoardInBrowser",
          "when": "view == youtrack.boards && viewItem == board",
          "group": "1_open@1"
        },
        {
          "command": "youtrack.markNotificationRead",
          "when": "view == youtrack.notifications && viewItem =~ /notif\\.unread/",
          "group": "inline@1"
        },
        {
          "command": "youtrack.markNotificationRead",
          "when": "view == youtrack.notifications && viewItem =~ /notif\\.unread/",
          "group": "1_notif@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "youtrack.createIssue",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "!terminalFocus && !editorTextFocus"
      },
      {
        "command": "youtrack.goToIssue",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "!terminalFocus"
      },
      {
        "command": "youtrack.search",
        "key": "ctrl+alt+y",
        "mac": "cmd+alt+y",
        "when": "!terminalFocus"
      },
      {
        "command": "youtrack.openBoard",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "!terminalFocus && !editorTextFocus"
      },
      {
        "command": "youtrack.peekIssue",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "viewsWelcome": [
      {
        "view": "youtrack.assignedToMe",
        "contents": "You're not signed in to YouTrack Cloud.\n[Sign In](command:youtrack.signIn)",
        "when": "!youtrack.signedIn"
      },
      {
        "view": "youtrack.issues",
        "contents": "Sign in to browse issues.",
        "when": "!youtrack.signedIn"
      },
      {
        "view": "youtrack.boards",
        "contents": "Sign in to see your agile boards.",
        "when": "!youtrack.signedIn"
      },
      {
        "view": "youtrack.recents",
        "contents": "No recently opened issues yet. Open one from any section and it will show up here.",
        "when": "youtrack.signedIn"
      },
      {
        "view": "youtrack.notifications",
        "contents": "Sign in to see your YouTrack notifications.",
        "when": "!youtrack.signedIn"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "test:integration": "tsc -p tsconfig.test.json && node ./test-dist/test/runTest.js",
    "changelog": "npx --yes auto-changelog --commit-limit false --hide-credit",
    "reinstall": "powershell -ExecutionPolicy Bypass -File ./.scripts/Reinstall-Extension.ps1"
  },
