{
  "name": "ls-youtrack-vscode",
  "displayName": "YouTrack for VS Code",
  "description": "YouTrack Cloud integration: sidebar, issue detail, time tracking, agile board, branch-from-issue.",
  "version": "0.1.0",
  "publisher": "lotchi-studio",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/youtrack.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "youtrack.refresh",
        "title": "YouTrack: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "youtrack.openIssue",
        "title": "YouTrack: Open Issue"
      },
      {
        "command": "youtrack.loadMore",
        "title": "YouTrack: Load More"
      },
      {
        "command": "youtrack.goToIssue",
        "title": "YouTrack: Go to Issue..."
      },
      {
        "command": "youtrack.search",
        "title": "YouTrack: Search..."
      },
      {
        "command": "youtrack.createIssue",
        "title": "YouTrack: Create Issue..."
      },
      {
        "command": "youtrack.assignToMe",
        "title": "YouTrack: Assign to Me"
      },
      {
        "command": "youtrack.changeState",
        "title": "YouTrack: Change State..."
      },
      {
        "command": "youtrack.logTime",
        "title": "YouTrack: Log Time..."
      },
      {
        "command": "youtrack.createBranch",
        "title": "YouTrack: Create Branch from Issue...",
        "icon": "$(git-branch)"
      },
      {
        "command": "youtrack.openBoard",
        "title": "YouTrack: Open Agile Board..."
      },
      {
        "command": "youtrack.signIn",
        "title": "YouTrack: Sign In..."
      },
      {
        "command": "youtrack.signOut",
        "title": "YouTrack: Sign Out"
      },
      {
        "command": "youtrack.filter",
        "title": "YouTrack: Filter Sidebar...",
        "icon": "$(filter)"
      },
      {
        "command": "youtrack.clearFilter",
        "title": "YouTrack: Clear Sidebar Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "youtrack.copyId",
        "title": "YouTrack: Copy Issue ID"
      },
      {
        "command": "youtrack.copyLink",
        "title": "YouTrack: Copy Issue Link"
      },
      {
        "command": "youtrack.openInBrowser",
        "title": "YouTrack: Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "youtrack.startWork",
        "title": "YouTrack: Start Work on Issue..."
      },
      {
        "command": "youtrack.groupByProject",
        "title": "YouTrack: Group by Project",
        "icon": "$(list-tree)"
      },
      {
        "command": "youtrack.groupFlat",
        "title": "YouTrack: Show Flat List",
        "icon": "$(list-flat)"
      }
    ],
    "configuration": {
      "title": "YouTrack",
      "properties": {
        "youtrack.baseUrl": {
          "type": "string",
          "default": "",
          "description": "YouTrack Cloud base URL."
        },
        "youtrack.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Short name of project used by Create Issue when set."
        },
        "youtrack.statusBarQuery": {
          "type": "string",
          "default": "for: me and #Unresolved",
          "description": "Query for the status bar counter."
        },
        "youtrack.cache.ttl.issues": {
          "type": "number",
          "default": 60,
          "description": "Issue cache TTL (seconds)."
        },
        "youtrack.cache.ttl.fieldSchemas": {
          "type": "number",
          "default": 3600,
          "description": "Custom field schemas TTL (seconds)."
        },
        "youtrack.cache.ttl.savedSearches": {
          "type": "number",
          "default": 300,
          "description": "Saved searches TTL (seconds)."
        },
        "youtrack.cache.pollInterval": {
          "type": "number",
          "default": 60,
          "description": "Background refresh interval (seconds)."
        },
        "youtrack.branch.template": {
          "type": "string",
          "default": "{assignee}/{id}-{summary}",
          "description": "Branch name template."
        },
        "youtrack.branch.summaryMaxLength": {
          "type": "number",
          "default": 40,
          "description": "Summary token max length."
        },
        "youtrack.branch.separator": {
          "type": "string",
          "default": "-",
          "description": "Separator for sanitized tokens."
        },
        "youtrack.branch.copyOnly": {
          "type": "boolean",
          "default": false,
          "description": "Copy to clipboard instead of creating the branch."
        },
        "youtrack.sidebar.groupBy": {
          "type": "string",
          "enum": ["none", "project"],
          "default": "project",
          "description": "How to group issues within each saved search in the sidebar."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "youtrack",
          "title": "YouTrack",
          "icon": "media/youtrack_outline.svg"
        }
      ]
    },
    "views": {
      "youtrack": [
        {
          "id": "youtrack.issues",
          "name": "Issues"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "youtrack.filter",
          "when": "view == youtrack.issues && !youtrack.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.clearFilter",
          "when": "view == youtrack.issues && youtrack.filterActive",
          "group": "navigation@1"
        },
        {
          "command": "youtrack.groupFlat",
          "when": "view == youtrack.issues && youtrack.groupedByProject",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.groupByProject",
          "when": "view == youtrack.issues && !youtrack.groupedByProject",
          "group": "navigation@2"
        },
        {
          "command": "youtrack.refresh",
          "when": "view == youtrack.issues",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "youtrack.createBranch",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "inline@1"
        },
        {
          "command": "youtrack.openInBrowser",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "inline@2"
        },
        {
          "command": "youtrack.startWork",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "1_work@1"
        },
        {
          "command": "youtrack.assignToMe",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "1_work@2"
        },
        {
          "command": "youtrack.changeState",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "1_work@3"
        },
        {
          "command": "youtrack.logTime",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "1_work@4"
        },
        {
          "command": "youtrack.createBranch",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "2_branch@1"
        },
        {
          "command": "youtrack.copyId",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "3_copy@1"
        },
        {
          "command": "youtrack.copyLink",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "3_copy@2"
        },
        {
          "command": "youtrack.openInBrowser",
          "when": "view == youtrack.issues && viewItem == issue",
          "group": "3_copy@3"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "youtrack.issues",
        "contents": "You're not signed in to YouTrack Cloud.\n[Sign In](command:youtrack.signIn)",
        "when": "!youtrack.signedIn"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package",
    "test:integration": "tsc -p tsconfig.test.json && node ./test-dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.0"
  }
}
