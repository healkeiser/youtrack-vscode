  "publisher": "healkeiser",
  "author": {
    "name": "Valentin Beaumont",
    "email": "valentin.onze@gmail.com"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "youtrack",
    "issue tracker",
    "issues",
    "agile",
    "kanban",
    "time tracking",
    "scrum",
    "jetbrains"
  ],
  "license": "MIT",
  "homepage": "https://github.com/healkeiser/youtrack-companion#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/healkeiser/youtrack-companion.git"
  },
  "bugs": {
    "url": "https://github.com/healkeiser/youtrack-companion/issues"
  },
